{"file":"callback-BF9L1ZrJ.js","mappings":";;;;;;;;;;;;;;;;;;;;AAec,aAAA;AACM,mBAAA;AACD,kBAAA;;AAhBZ,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,mDAA+C,MAAA,CAAA,CAAA,8JAAA;AAAA;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps"],"sources":["../../../../../../../app/pages/auth/callback.vue"],"sourcesContent":["<template>\n  <div class=\"flex justify-center items-center min-h-screen\">\n    <div class=\"text-center\">\n      <div class=\"loading loading-spinner loading-lg\"></div>\n      <p class=\"mt-4 text-lg\">Processing AniList authentication...</p>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { navigateTo } from '#app';\nimport { useRoute } from '#app';\nimport { useAnilistAuth } from '~/composables/useAnilistAuth';\nimport { useAlertStore } from '~/composables/useAlertStore';\n\nconst route = useRoute();\nconst anilistAuth = useAnilistAuth();\nconst alertStore = useAlertStore();\n\n// On component mount, check for the authorization code in the URL\nonMounted(async () => {\n  // Extract the authorization code from the URL query parameters\n  const code = route.query.code as string;\n  const error = route.query.error as string;\n\n  if (error) {\n    // Handle error from AniList\n    const errorDescription = route.query.error_description as string;\n    // Using a timeout to prevent blocking the UI while showing the alert\n    setTimeout(() => {\n      alertStore.openAlert({\n        type: 'error',\n        message: errorDescription || error\n      });\n    }, 0);\n    // Redirect to home or profile page\n    navigateTo('/profilePage');\n    return;\n  }\n\n  if (!code) {\n    // If no code is present, redirect to profile page\n    // Using a timeout to prevent blocking the UI while showing the alert\n    setTimeout(() => {\n      alertStore.openAlert({\n        type: 'warning',\n        message: 'No authorization code received from AniList'\n      });\n    }, 0);\n    navigateTo('/profilePage');\n    return;\n  }\n\n  // Handle the AniList callback with the authorization code\n  await anilistAuth.handleAnilistCallback(code);\n});\n</script>"],"version":3}